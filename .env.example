# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/change_quality_agent

# Logging
LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=true

# Authentication
AUTH_ENABLED=true
AUTH_DEV_MODE=false
AUTH_SESSION_COOKIE_NAME=cqa_user
# Set these only when AUTH_DEV_MODE=true and stable seeded dev tokens are needed.
AUTH_DEV_COMMON_REFRESH_TOKEN=
AUTH_DEV_ADMIN_REFRESH_TOKEN=

# MCP runtime
MCP_OPERATION_TIMEOUT_SECONDS=10
MCP_RUNTIME_SINGLE_INSTANCE=false
MCP_ALLOWED_STDIO_COMMANDS=[]
MCP_ALLOWED_STDIO_SPECS=[]

# CodeAgent/LangChain provider integration
CODEAGENT_BASE_URL=
CODEAGENT_TOKEN_PROVIDER=codeagent
SOP_QUALITY_AGENT_ID=
